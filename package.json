{
  "name": "acp-visualizer-tui",
  "version": "0.2.7",
  "description": "Terminal-based interactive visualizer for ACP progress.yaml data",
  "type": "module",
  "bin": {
    "acp-visualizer-tui": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "acp",
    "agent-context-protocol",
    "tui",
    "terminal",
    "visualizer",
    "progress",
    "cli",
    "ink"
  ],
  "author": "prmichaelsen",
  "license": "MIT",
  "dependencies": {
    "fuse.js": "^7.1.0",
    "ink": "^6.8.0",
    "js-yaml": "^4.1.1",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "meow": "^14.1.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
